@using JardinConecta.Models.ViewModels
@model VerificacionEmailResultViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verificá tu cuenta — JardinConecta</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="margin:0; padding:0; background-color:#F3E8FF; font-family:'Poppins', Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F3E8FF; padding: 40px 0;">
    <tr>
      <td align="center">

        <!-- Card -->
        <table width="860" cellpadding="0" cellspacing="0" border="0"
               style="max-width:560px; width:100%; border-radius:16px; overflow:hidden;
                      box-shadow: 0 4px 24px rgba(103,58,183,0.12);">

          <!-- Header -->
          <tr>
            <td align="center"
                style="background-color:#673AB7; padding: 28px 0 22px;">

            <!-- Icon -->
            <img height="50" src="https://jardinconecta.com/assets/img/splash-hollow-inline.png" alt="">


              <!-- <p style="margin:0 0 0; font-size:13px; font-weight:400;
                         color:#D1C4E9; letter-spacing:0.3px;">
                Conectando familias y educadores
              </p> -->
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background-color:#FFFFFF; padding: 44px 48px 40px;">

              <!-- Title -->
              <!-- <p style="margin:0 0 12px; font-size:22px; font-weight:700;
                         color:#311B92; text-align:center; line-height:1.3;">
                
              </p> -->

              <!-- Subtitle -->
                @if (Model.Success)
                {
                    <p style="margin:0 0 0; font-size:15px; font-weight:400;
                        color:#616161; text-align:center; line-height:1.6;">
                     <strong style="color:#4CAF50;">Email verificado correctamente.</strong>
                     <!-- <strong style="color:#673AB7;">Email verificado correctamente.</strong> -->

                     <br>
                        Ya podés volver a la app.
                    </p>
                }
                else
                {
                    <p style="margin:0 0 0; font-size:15px; font-weight:400;
                        color:#616161; text-align:center; line-height:1.6;">
                     <strong style="color:#dc3545;">Algo salió mal.</strong>
                     <br>
                       No pudimos verificar tu email.
                    </p>
                }
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color:#F9F5FF; padding: 24px 48px;
                        border-top: 1px solid #EDE7F6;">
              <p style="margin:14px 0 0; font-size:12px; font-weight:600;
                         color:#B39DDB; text-align:center; letter-spacing:0.3px;">
                © @DateTime.Now.Year JardinConecta
              </p>
            </td>
          </tr>
        </table>
        <!-- /Card -->

      </td>
    </tr>
  </table>

</body>
</html>
